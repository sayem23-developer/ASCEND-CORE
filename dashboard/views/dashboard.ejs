<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>ASCEND CORE Dashboard</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#0b1120;
    color:white;
    display:flex;
}


/* Sidebar */

.sidebar{
    width:260px;
    height:100vh;
    background:#111827;
    padding:25px;
    position:fixed;
}

.logo{
    font-size:24px;
    font-weight:bold;
    color:#facc15;
    margin-bottom:30px;
}

.menu a{
    display:block;
    color:#cbd5e1;
    text-decoration:none;
    padding:12px;
    margin:8px 0;
    border-radius:10px;
}

.menu a:hover{
    background:#1e293b;
    color:white;
}


/* Main */

.main{
    margin-left:260px;
    padding:30px;
    width:100%;
}


.top{
    display:flex;
    justify-content:space-between;
    align-items:center;
}


.logout{
    background:#5865F2;
    color:white;
    padding:10px 18px;
    border-radius:10px;
    text-decoration:none;
}


/* Cards */

.cards{
    display:flex;
    gap:20px;
    margin-top:30px;
    flex-wrap:wrap;
}


.card{
    background:#1e293b;
    padding:25px;
    border-radius:15px;
    width:200px;
}


.card h3{
    color:#facc15;
}


@media(max-width:700px){

.sidebar{
    width:100px;
}

.sidebar .menu a{
    font-size:12px;
}

.main{
    margin-left:100px;
}

}

</style>

</head>


<body>


<div class="sidebar">

<div class="logo">
⚡ ASCEND CORE
</div>


<div class="menu">

<a href="/">
🏠 Home
</a>

<a href="#">
📊 Statistics
</a>

<a href="#">
⚙️ Setup
</a>

<a href="#">
👋 Welcome
</a>

<a href="#">
🎫 Tickets
</a>

<a href="#">
📜 Logs
</a>

<a href="#">
🛡️ Moderation
</a>

<a href="/botinfo">
🤖 Bot Info
</a>

</div>

</div>

</div>

</div>



<div class="main">


<div class="top">

<h1>
Dashboard
</h1>


<a class="logout" href="/logout">
Logout
</a>


</div>



<h2 style="margin-top:20px;">
Welcome <%= user.username %> 👋
</h2>



<div class="cards">


<div class="card">
<h3>🤖 Bot</h3>
<p>Online</p>
</div>


<div class="card">
<h3>🌐 Servers</h3>
<p><%= client.guilds.cache.size %></p>
</div>


<div class="card">
<h3>👥 Users</h3>
<p><%= client.users.cache.size %></p>
</div>


<div class="card">
<h3>⚡ Status</h3>
<p>Running</p>
</div>


</div>


</div>


</body>
</html>
