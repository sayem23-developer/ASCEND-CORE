<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ASCEND CORE v3</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,Helvetica,sans-serif;
}

body{
height:100vh;
display:flex;
justify-content:center;
align-items:center;
background:#0f172a;
color:#fff;
}

.card{
width:380px;
padding:40px;
border-radius:20px;
background:#1e293b;
text-align:center;
box-shadow:0 0 30px rgba(0,0,0,.4);
}

.logo{
font-size:30px;
font-weight:bold;
color:#facc15;
margin-bottom:10px;
}

.version{
color:#94a3b8;
margin-bottom:30px;
}

.login-btn{
display:block;
width:100%;
padding:15px;
border-radius:12px;
background:#5865F2;
color:#fff;
text-decoration:none;
font-size:18px;
font-weight:bold;
transition:.3s;
}

.login-btn:hover{
background:#4752c4;
}

.footer{
margin-top:20px;
font-size:13px;
color:#94a3b8;
}
</style>

</head>

<body>

<div class="card">

<div class="logo">
ASCEND CORE
</div>

<div class="version">
v3 Dashboard
</div>

<a class="login-btn" href="/auth/discord">
Login with Discord
</a>

<div class="footer">
Powered by ASCEND CORE
</div>

</div>

</body>
</html>
